<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical">

    <!-- Иконка автомобиля -->
    <ImageView
        android:id="@+id/carIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Car"
        android:padding="4dp"
        android:src="@drawable/directions_car" />

    <!-- Информация об автомобиле -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/carName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toyota Camry"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/carMileage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Пробег: 50000 км"
            android:textColor="#666666"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Индикатор выбранного автомобиля -->
    <ImageView
        android:id="@+id/carSelectedIndicator"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/presence_online"
        android:visibility="gone"
        android:contentDescription="Selected" />

</LinearLayout>
